PORT=3847
# Use 127.0.0.1 only if the reverse proxy runs on the same host. Use 0.0.0.0 when NPM is remote (firewall the port).
BIND_HOST=0.0.0.0
SESSION_SECRET=change-me-to-a-long-random-string
DATABASE_PATH=./data/feedback.db

# Staff credentials (used by seed-staff on first run)
STAFF_USERNAME=staff
STAFF_PASSWORD=change-me

# Pretalx (optional — can be configured in the staff UI under Pretalx)
# Used as defaults on first startup only; saved settings in the database take precedence.
PRETALX_BASE_URL=https://speakers.southeastlinuxfest.org
PRETALX_EVENT_SLUG=southeast-linux-fest-2026
PRETALX_ALLOWED_HOSTS=speakers.southeastlinuxfest.org
SCHEDULE_SYNC_INTERVAL_MINUTES=60

# MQTT (optional — can be configured in the staff UI under MQTT)
# Used as defaults on first startup only; saved settings in the database take precedence.
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=vote/
MQTT_UPTIME_TOPIC=+/sensor/uptime_sensor/state
MQTT_RECONNECT_MS=5000

# Telegram reboot alerts (optional — can be configured in the staff UI under Telegram)
# TELEGRAM_ALERTS_ENABLED=true
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Event timezone for display (Pretalx slots include offset)
DISPLAY_TIMEZONE=America/New_York

# Session cookie Secure flag.
# Omit or set auto (default in production): uses HTTPS detection via X-Forwarded-Proto (NPM).
# Set false only for direct HTTP testing without a proxy.
# COOKIE_SECURE=true
